{
  "name": "sveltekit-fullstack-template",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --bun vite dev",
    "build": "bun vite build",
    "preview": "bun --bun vite preview",
    "sync": "bun sync:packages && bun sync:this",
    "sync:packages": "true # use `bun --filter='*' sync` if you need to",
    "sync:this": "svelte-kit sync",
    "prepare": "bun sync && bun lefthook install",
    "check": "bun check:types && bun check:format",
    "check:types": "bun sync && svelte-check --tsconfig ./tsconfig.json",
    "check:format": "bun biome check . && bun prettier . --check",
    "fix": "bun format",
    "format": "bun biome check . --fix --unsafe && bun prettier . --write",
    "db": "bun drizzle-kit",
    "install:production": "bun i --frozen-lockfile --ignore-scripts && bun sync"
  },
  "dependencies": {
    "@iconify/svelte": "^5.0.1",
    "@libsql/client": "^0.15.10",
    "@sveltejs/kit": "^2.27.1",
    "@sveltejs/vite-plugin-svelte": "^6.1.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.1.11",
    "@types/bun": "^1.2.19",
    "better-auth": "^1.3.4",
    "daisyui": "^5.0.50",
    "drizzle-orm": "^0.44.4",
    "drizzle-valibot": "^0.4.2",
    "runed": "0.31.1",
    "svelte": "^5.38.0",
    "svelte-adapter-bun": "^0.5.2",
    "svelte-check": "^4.3.1",
    "svelte-easy-crop": "^4.0.1",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.9.2",
    "valibot": "^1.1.0",
    "vite": "^7.0.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.3",
    "drizzle-kit": "^0.31.4",
    "lefthook": "^1.12.2",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "wrangler": "^4.28.0"
  }
}
